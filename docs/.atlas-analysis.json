{
  "projectType": "cli-tool",
  "projectName": "fp-appimage-updater",
  "projectDescription": "A declarative, single-binary CLI tool for managing and auto-updating AppImages on Linux using YAML recipes.",
  "theme": "aspen",
  "primaryColor": "#fb6c24",
  "lightColor": "#fba224",
  "darkColor": "#2f2e6d",
  "navigation": {
    "groups": [
      {
        "group": "Get Started",
        "pages": [
          "introduction",
